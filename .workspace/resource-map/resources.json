{
  "$schema": "jm-forge:resource-map:v1",
  "description": "Resource registry for jm-forge. Stores all entities managed by the project (人、财、物、信息).",

  "resources": [
    {
      "id": "example-dumper-truck-01",
      "name": "翻斗车 #01",
      "category": "equipment",
      "description": "主要负责A区土方运输",
      "controllable": true,
      "safety": {
        "level": "medium",
        "requiresConfirmation": true,
        "destructiveActionsAllowed": false
      },
      "attributes": {
        "type": "翻斗车",
        "capacity": "20立方",
        "status": "运行中",
        "location": "A区施工现场",
        "driver": "王五",
        "fuel": "柴油"
      },
      "relationships": [
        {
          "to": "example-site-area-a",
          "type": "assigned-to",
          "description": "分配至A区施工"
        }
      ],
      "notes": "日常维护周期：500小时"
    },
    {
      "id": "example-prod-server",
      "name": "生产服务器",
      "category": "infrastructure",
      "description": "承载核心业务服务",
      "controllable": true,
      "safety": {
        "level": "high-caution",
        "requiresConfirmation": true,
        "destructiveActionsAllowed": false
      },
      "attributes": {
        "host": "prod.jiya.com",
        "os": "Ubuntu 22.04",
        "cpu": "8 cores",
        "memory": "32GB",
        "keyPaths": [
          {"path": "/opt/jiya/services/", "description": "应用目录"},
          {"path": "/etc/jiya/config/", "description": "配置文件"}
        ],
        "keyServices": [
          {"name": "jiya-server", "description": "主服务"},
          {"name": "nginx", "description": "反向代理"},
          {"name": "redis", "description": "缓存服务"}
        ]
      },
      "relationships": [
        {
          "to": "example-racobit-server",
          "type": "hosts",
          "description": "运行racobit-server"
        }
      ],
      "notes": "通过supervisor管理服务，SSH Key在 ~/.ssh/prod_ed25519"
    },
    {
      "id": "example-partner-abc",
      "name": "外包公司 ABC",
      "category": "organization",
      "description": "负责模块X开发",
      "controllable": false,
      "safety": {
        "level": "none",
        "requiresConfirmation": false,
        "destructiveActionsAllowed": false
      },
      "attributes": {
        "type": "外包合作伙伴",
        "contacts": [
          {"name": "张三", "role": "技术负责人", "contact": "zhangsan@abc-partner.com"},
          {"name": "李四", "role": "项目经理", "contact": "lisi@abc-partner.com"}
        ],
        "repositories": [
          {"name": "他们负责的模块", "location": "git@github.com:abc-partner/module-x.git"}
        ],
        "contractEnd": "2026-12-31"
      },
      "relationships": [
        {
          "to": "example-module-x",
          "type": "develops",
          "description": "负责模块X"
        }
      ],
      "notes": "2026年Q2有合同续签评估"
    }
  ],

  "_schema_version": "1.0",
  "_map_cascade": {
    "stage": "initial",
    "entry": "INDEX.md",
    "order": [
      "INDEX.md",
      "resources.json"
    ]
  },
  "_comments": {
    "core_fields": ["id", "name", "category", "description", "controllable", "safety", "relationships", "attributes", "notes"],
    "category_options": ["infrastructure", "document", "organization", "human", "financial", "equipment", "api", "repository", "secret", "other"],
    "safety_levels": ["none", "low", "medium", "high-caution", "restricted"]
  }
}
